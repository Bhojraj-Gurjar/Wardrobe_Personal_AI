{
  "info": {
    "name": "Wardrobe AI API",
    "_postman_id": "wardrobe-ai-api-collection",
    "description": "Import this collection into Postman to test the Wardrobe AI backend.\n\n**Setup**\n1. Import `Wardrobe-AI.postman_environment.json` and select the **Wardrobe AI - Local** environment.\n2. Run **Auth → Login** (or Register) — tokens are saved automatically.\n3. Call protected endpoints; Bearer auth uses `{{accessToken}}`.\n\n**Base URL:** `{{baseUrl}}` (default: http://localhost:3000/api/v1)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1" },
    { "key": "accessToken", "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "productId", "value": "" },
    { "key": "orderId", "value": "" },
    { "key": "wishlistItemId", "value": "" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/health"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "if (res.data?.refreshToken) pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "if (pm.environment.name) {",
                  "  if (res.data?.accessToken) pm.environment.set('accessToken', res.data.accessToken);",
                  "  if (res.data?.refreshToken) pm.environment.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"mobile\": \"+919876543210\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        },
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "if (res.data?.refreshToken) pm.collectionVariables.set('refreshToken', res.data.refreshToken);",
                  "if (pm.environment.name) {",
                  "  if (res.data?.accessToken) pm.environment.set('accessToken', res.data.accessToken);",
                  "  if (res.data?.refreshToken) pm.environment.set('refreshToken', res.data.refreshToken);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/refresh"
          }
        },
        {
          "name": "Logout",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "Get Profile",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/users/profile" }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"gender\": \"FEMALE\",\n  \"age\": 28,\n  \"height\": 165,\n  \"weight\": 62,\n  \"body_type\": \"AVERAGE\",\n  \"skin_tone\": \"MEDIUM\"\n}"
            },
            "url": "{{baseUrl}}/users/profile"
          }
        }
      ]
    },
    {
      "name": "Products",
      "auth": { "type": "noauth" },
      "item": [
        {
          "name": "List Products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products?page=1&limit=20&search=&sortBy=created_at&sortOrder=desc",
              "host": ["{{baseUrl}}"],
              "path": ["products"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "search", "value": "" },
                { "key": "sortBy", "value": "created_at" },
                { "key": "sortOrder", "value": "desc" },
                { "key": "category_id", "value": "", "disabled": true },
                { "key": "brand_id", "value": "", "disabled": true },
                { "key": "min_price", "value": "", "disabled": true },
                { "key": "max_price", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Product by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Create Product",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sku\": \"SKU-001\",\n  \"name\": \"Classic Denim Jacket\",\n  \"description\": \"Premium denim jacket for all seasons\",\n  \"category_id\": \"category-uuid\",\n  \"brand_id\": \"brand-uuid\",\n  \"price\": 79.99,\n  \"images\": [\n    {\n      \"url\": \"https://cdn.example.com/product.jpg\",\n      \"sort_order\": 0,\n      \"is_primary\": true\n    }\n  ]\n}"
            },
            "url": "{{baseUrl}}/products"
          }
        },
        {
          "name": "Update Product",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Updated Denim Jacket\",\n  \"price\": 89.99\n}"
            },
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        },
        {
          "name": "Delete Product",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/products/{{productId}}"
          }
        }
      ]
    },
    {
      "name": "Recommendations",
      "item": [
        {
          "name": "Get Recommendations",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/recommendations?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["recommendations"],
              "query": [{ "key": "limit", "value": "10" }]
            }
          }
        }
      ]
    },
    {
      "name": "Fashion DNA",
      "item": [
        {
          "name": "Get Fashion DNA",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/fashion-dna" }
        },
        {
          "name": "Generate Fashion DNA",
          "request": { "method": "POST", "header": [], "url": "{{baseUrl}}/fashion-dna/generate" }
        }
      ]
    },
    {
      "name": "Wishlist",
      "item": [
        {
          "name": "Get Wishlist",
          "request": { "method": "GET", "header": [], "url": "{{baseUrl}}/wishlist" }
        },
        {
          "name": "Add to Wishlist",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"product_id\": \"{{productId}}\"\n}"
            },
            "url": "{{baseUrl}}/wishlist"
          }
        },
        {
          "name": "Remove from Wishlist",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": "{{baseUrl}}/wishlist/{{wishlistItemId}}"
          }
        }
      ]
    },
    {
      "name": "Orders",
      "item": [
        {
          "name": "Create Order",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"total_amount\": 149.99\n}"
            },
            "url": "{{baseUrl}}/orders"
          }
        },
        {
          "name": "List Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders?page=1&limit=20",
              "host": ["{{baseUrl}}"],
              "path": ["orders"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" }
              ]
            }
          }
        },
        {
          "name": "Get Order by ID",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/orders/{{orderId}}"
          }
        }
      ]
    },
    {
      "name": "Face",
      "item": [
        {
          "name": "Register Face",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"embedding\": [0.12, -0.05, 0.88, 0.41, -0.19]\n}"
            },
            "url": "{{baseUrl}}/face/register"
          }
        },
        {
          "name": "Face Login",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"embedding\": [0.12, -0.05, 0.88, 0.41, -0.19]\n}"
            },
            "url": "{{baseUrl}}/face/login"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data?.accessToken) pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "if (res.data?.refreshToken) pm.collectionVariables.set('refreshToken', res.data.refreshToken);"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
