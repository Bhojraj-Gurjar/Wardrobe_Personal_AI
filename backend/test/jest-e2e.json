{
  "moduleFileExtensions": ["js", "json"],
  "rootDir": ".",
  "testRegex": ".e2e-spec.js$",
  "transform": {
    "^.+\\.js$": [
      "@swc/jest",
      {
        "jsc": {
          "parser": {
            "syntax": "ecmascript",
            "decorators": true
          },
          "transform": {
            "legacyDecorator": true,
            "decoratorMetadata": true
          },
          "target": "es2022",
          "keepClassNames": true
        },
        "module": {
          "type": "commonjs"
        }
      }
    ]
  }
}
