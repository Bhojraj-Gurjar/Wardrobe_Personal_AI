NODE_ENV=development
PORT=3000
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

DATABASE_URL=postgresql://wardrobe:wardrobe@localhost:5432/wardrobe_db?schema=public
JWT_SECRET=dev-secret-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

REDIS_HOST=localhost
REDIS_PORT=6379

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=products
QDRANT_VECTOR_SIZE=128
QDRANT_FACE_COLLECTION=users_face_vectors
QDRANT_DNA_COLLECTION=fashion_dna_vectors
QDRANT_FACE_ANALYSIS_COLLECTION=face_analysis_vectors
QDRANT_BODY_ANALYSIS_COLLECTION=body_analysis_vectors
QDRANT_DIGITAL_AVATAR_COLLECTION=digital_avatar_vectors
FACE_VECTOR_SIZE=512
DNA_VECTOR_SIZE=384
FACE_ANALYSIS_VECTOR_SIZE=384
BODY_ANALYSIS_VECTOR_SIZE=384
DIGITAL_AVATAR_VECTOR_SIZE=384
FACE_SIMILARITY_THRESHOLD=0.40
FACE_REGISTRATION_DUPLICATE_THRESHOLD=0.45
FACE_SIMILARITY_UNCERTAIN=0.32

AI_SERVICE_URL=http://localhost:8000

OPENAI_API_KEY=

# Avatar image storage (local filesystem only)
STORAGE_PROVIDER=local
STORAGE_LOCAL_ROOT=uploads
STORAGE_PUBLIC_BASE_URL=http://localhost:3000
STORAGE_PUBLIC_PATH=/uploads
