generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BodyType {
  SLIM
  ATHLETIC
  AVERAGE
  CURVY
  PLUS_SIZE
}

enum SkinTone {
  FAIR
  LIGHT
  MEDIUM
  OLIVE
  TAN
  BROWN
  DARK
}

enum ProductCategoryGroupCode {
  MEN
  WOMEN
  ACCESSORIES
  FOOTWEAR
}

enum AvatarCategory {
  TOP
  JACKET
  BOTTOM
  FOOTWEAR
  ACCESSORY
}

model User {
  id               String      @id @default(uuid())
  email            String      @unique
  mobile           String?     @unique
  password_hash    String      @map("password_hash")
  role             UserRole    @default(USER)
  status           UserStatus  @default(ACTIVE)
  admin_created_at DateTime?   @map("admin_created_at")
  created_at       DateTime    @default(now()) @map("created_at")
  updated_at       DateTime    @updatedAt @map("updated_at")
  profile          UserProfile?
  wishlist         Wishlist[]
  cart_items       CartItem[]
  orders           Order[]
  fashion_dna   FashionDna?
  fashion_dna_history FashionDnaHistory[]
  face_registration FaceRegistration?
  face_analysis   FaceAnalysis?
  body_analysis   BodyAnalysis?
  digital_avatars DigitalAvatar[]
  virtual_try_on  VirtualTryOn?
  virtual_try_on_results VirtualTryOnResult[]
  try_on_results  TryOnResult[]
  saved_outfits   SavedOutfit[]
  personal_closet PersonalClosetItem[]
  favorite_brands FavoriteBrand[]
  favorite_colors FavoriteColor[]
  product_views ProductView[]
  search_history SearchHistory[]

  @@map("users")
}

model FaceRegistration {
  id                 String   @id @default(uuid())
  user_id            String   @unique @map("user_id")
  face_embedding_id  String   @map("face_embedding_id")
  face_image_url     String?  @map("face_image_url") @db.VarChar(2048)
  is_face_registered Boolean  @default(true) @map("is_face_registered")
  liveness_score     Float?   @map("liveness_score")
  blink_detected     Boolean  @default(false) @map("blink_detected")
  smile_detected     Boolean  @default(false) @map("smile_detected")
  registered_at      DateTime @default(now()) @map("registered_at")
  updated_at         DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("face_registrations")
}

model FaceAnalysis {
  id              String   @id @default(uuid())
  user_id         String   @unique @map("user_id")
  face_shape      String?  @map("face_shape")
  skin_tone       String?  @map("skin_tone")
  hair_length     String?  @map("hair_length")
  hair_color      String?  @map("hair_color")
  hair_style      String?  @map("hair_style")
  beard_type      String?  @map("beard_type")
  raw_ai_response Json?    @map("raw_ai_response")
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("face_analysis")
}

model BodyAnalysis {
  id              String   @id @default(uuid())
  user_id         String   @unique @map("user_id")
  body_image_url  String?  @map("body_image_url") @db.VarChar(2048)
  body_type       String?  @map("body_type")
  body_shape      String?  @map("body_shape")
  height          Float?
  shoulder_width  Float?   @map("shoulder_width")
  chest           Float?
  waist           Float?
  hip             Float?
  arm_length      Float?   @map("arm_length")
  leg_length      Float?   @map("leg_length")
  fit_profile     Json?    @map("fit_profile")
  raw_ai_response Json?    @map("raw_ai_response")
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("body_analysis")
}

model DigitalAvatar {
  id              String   @id @default(uuid())
  user_id         String   @map("user_id")
  avatar_type     String   @map("avatar_type")
  avatar_image    String   @map("avatar_image") @db.VarChar(2048)
  version         Int
  is_active       Boolean  @default(false) @map("is_active")
  raw_ai_response Json?    @map("raw_ai_response")
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, version])
  @@index([user_id, is_active])
  @@map("digital_avatars")
}

model UserProfile {
  id          String    @id @default(uuid())
  user_id     String    @unique @map("user_id")
  name        String?
  gender      Gender?
  age         Int?
  height      Float?
  weight      Float?
  country     String?
  language    String?
  body_type   BodyType? @map("body_type")
  skin_tone   SkinTone? @map("skin_tone")
  preferences Json?
  body_image  String?   @map("body_image") @db.VarChar(2048)
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at  DateTime  @default(now()) @map("created_at")
  updated_at  DateTime  @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model ProductCategoryGroup {
  id          String                   @id @default(uuid())
  code        ProductCategoryGroupCode @unique
  name        String
  description String?
  sort_order  Int                      @default(0) @map("sort_order")
  is_active   Boolean                  @default(true) @map("is_active")
  created_at  DateTime                 @default(now()) @map("created_at")
  updated_at  DateTime                 @updatedAt @map("updated_at")
  categories  ProductCategory[]

  @@index([is_active])
  @@index([sort_order])
  @@map("product_category_groups")
}

model ProductCategory {
  id         String               @id @default(uuid())
  group_id   String               @map("group_id")
  slug       String               @unique
  name       String
  sort_order Int                  @default(0) @map("sort_order")
  is_active  Boolean              @default(true) @map("is_active")
  created_at DateTime             @default(now()) @map("created_at")
  updated_at DateTime             @updatedAt @map("updated_at")
  group      ProductCategoryGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([group_id, name])
  @@index([group_id])
  @@index([is_active])
  @@index([sort_order])
  @@map("product_categories")
}

model Product {
  id                 String         @id @default(uuid())
  sku                String         @unique
  name               String
  description        String?
  category           String?
  subcategory        String?
  product_type       String         @default("T-Shirt") @map("product_type")
  gender             String?
  brand              String?
  category_id        String?        @map("category_id")
  brand_id           String?        @map("brand_id")
  price              Float
  currency           String         @default("USD")
  color              String?
  size_options       Json?          @map("size_options")
  fabric             String?
  fit_type           String?        @map("fit_type")
  style_tags         Json?          @map("style_tags")
  occasion_tags      Json?          @map("occasion_tags")
  image_url          String?        @map("image_url") @db.VarChar(2048)
  product_url        String?        @map("product_url") @db.VarChar(2048)
  avatar_category    AvatarCategory? @map("avatar_category")
  overlay_order      Int?            @map("overlay_order")
  avatar_overlay_url String?        @map("avatar_overlay_url") @db.VarChar(2048)
  try_on_image       String?        @map("try_on_image") @db.VarChar(2048)
  is_try_on_compatible Boolean?     @map("is_try_on_compatible")
  is_active          Boolean        @default(true) @map("is_active")
  created_at         DateTime       @default(now()) @map("created_at")
  updated_at         DateTime       @updatedAt @map("updated_at")
  images             ProductImage[]
  wishlist           Wishlist[]
  cart_items         CartItem[]
  product_views      ProductView[]
  orders             Order[]
  try_on_results     TryOnResult[]

  @@index([category])
  @@index([subcategory])
  @@index([product_type])
  @@index([category, product_type])
  @@index([gender])
  @@index([brand])
  @@index([category_id])
  @@index([brand_id])
  @@index([price])
  @@index([is_active])
  @@index([category, subcategory])
  @@index([gender, category])
  @@index([avatar_category])
  @@index([overlay_order])
  @@index([avatar_category, overlay_order])
  @@map("products")
}

model ProductImage {
  id         String   @id @default(uuid())
  product_id String   @map("product_id")
  url        String
  sort_order Int      @default(0) @map("sort_order")
  is_primary Boolean  @default(false) @map("is_primary")
  created_at DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_images")
}

model Wishlist {
  id         String   @id @default(uuid())
  user_id    String   @map("user_id")
  product_id String   @map("product_id")
  created_at DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@index([user_id])
  @@map("wishlist")
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PACKED
  SHIPPED
  DELIVERED
  CANCELLED
}

model CartItem {
  id         String   @id @default(uuid())
  user_id    String   @map("user_id")
  product_id String   @map("product_id")
  quantity   Int      @default(1)
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@index([user_id])
  @@map("cart_items")
}

model Order {
  id           String      @id @default(uuid())
  user_id      String      @map("user_id")
  product_id   String?     @map("product_id")
  order_number String?     @map("order_number")
  total_amount Float       @map("total_amount")
  subtotal     Float?
  shipping     Float?
  discount     Float?
  coupon_code  String?     @map("coupon_code")
  metadata     Json?
  status       OrderStatus @default(CREATED)
  created_at   DateTime    @default(now()) @map("created_at")
  updated_at   DateTime    @updatedAt @map("updated_at")
  user         User        @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product      Product?    @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([user_id])
  @@index([status])
  @@index([product_id])
  @@index([order_number])
  @@map("orders")
}

model FashionDna {
  id                       String   @id @default(uuid())
  user_id                  String   @unique @map("user_id")
  style_type               String   @map("style_type")
  color_affinity           Json     @map("color_affinity")
  budget_range             String   @map("budget_range")
  brand_affinity           Json     @map("brand_affinity")
  fashion_confidence_score Float    @map("fashion_confidence_score")
  face_traits              Json     @map("face_traits")
  body_traits              Json     @map("body_traits")
  preference_traits        Json     @map("preference_traits")
  activity_traits          Json     @default("{}") @map("activity_traits")
  created_at               DateTime @default(now()) @map("created_at")
  updated_at               DateTime @updatedAt @map("updated_at")
  user                     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("fashion_dna")
}

model FashionDnaHistory {
  id                       String   @id @default(uuid())
  user_id                  String   @map("user_id")
  fashion_dna_id           String   @map("fashion_dna_id")
  change_reason            String   @map("change_reason")
  change_source            String?  @map("change_source")
  style_type               String   @map("style_type")
  color_affinity           Json     @map("color_affinity")
  budget_range             String   @map("budget_range")
  brand_affinity           Json     @map("brand_affinity")
  fashion_confidence_score Float    @map("fashion_confidence_score")
  face_traits              Json     @map("face_traits")
  body_traits              Json     @map("body_traits")
  preference_traits        Json     @map("preference_traits")
  activity_traits          Json     @default("{}") @map("activity_traits")
  dna_created_at           DateTime @map("dna_created_at")
  dna_updated_at           DateTime @map("dna_updated_at")
  archived_at              DateTime @default(now()) @map("archived_at")
  user                     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, archived_at])
  @@index([fashion_dna_id])
  @@map("fashion_dna_history")
}

model ProductView {
  id         String   @id @default(uuid())
  user_id    String   @map("user_id")
  product_id String   @map("product_id")
  viewed_at  DateTime @default(now()) @map("viewed_at")
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([user_id, viewed_at])
  @@index([product_id])
  @@map("product_views")
}

model SearchHistory {
  id          String   @id @default(uuid())
  user_id     String   @map("user_id")
  query       String
  searched_at DateTime @default(now()) @map("searched_at")
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, searched_at])
  @@map("search_history")
}

model VirtualTryOn {
  id                     String   @id @default(uuid())
  user_id                String   @unique @map("user_id")
  body_image             String?  @map("body_image") @db.VarChar(2048)
  transparent_image      String?  @map("transparent_image") @db.VarChar(2048)
  selected_products      Json     @default("[]") @map("selected_products")
  generated_outfit_image String?  @map("generated_outfit_image") @db.VarChar(2048)
  created_at             DateTime @default(now()) @map("created_at")
  updated_at             DateTime @updatedAt @map("updated_at")
  user                   User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("virtual_try_on")
}

model VirtualTryOnResult {
  id                   String   @id @default(uuid())
  user_id              String   @map("user_id")
  product_id           String?  @map("product_id")
  body_photo_reference String?  @map("body_photo_reference") @db.VarChar(2048)
  garment_image        String?  @map("garment_image") @db.VarChar(2048)
  input_image          String?  @map("input_image") @db.VarChar(2048)
  transparent_image    String?  @map("transparent_image") @db.VarChar(2048)
  generated_image      String?  @map("generated_image") @db.VarChar(2048)
  selected_products    Json     @default("[]") @map("selected_products")
  created_at           DateTime @default(now()) @map("created_at")
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@map("virtual_tryons")
}

model TryOnResult {
  id              String   @id @default(uuid())
  user_id         String   @map("user_id")
  product_id      String?  @map("product_id")
  body_image      String?  @map("body_image") @db.VarChar(2048)
  garment_image   String?  @map("garment_image") @db.VarChar(2048)
  generated_image String?  @map("generated_image") @db.VarChar(2048)
  created_at      DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([product_id])
  @@map("try_on_results")
}

model SavedOutfit {
  id            String   @id @default(uuid())
  user_id       String   @map("user_id")
  name          String?
  products      Json     @default("[]")
  items         Json     @default("[]")
  preview_image String?  @map("preview_image") @db.VarChar(2048)
  thumbnail     String?  @db.VarChar(2048)
  total_price   Float?   @map("total_price")
  source        String?
  created_at    DateTime @default(now()) @map("created_at")
  updated_at    DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@map("saved_outfits")
}

model PersonalClosetItem {
  id           String   @id @default(uuid())
  user_id      String   @map("user_id")
  order_id     String   @map("order_id")
  product_id   String   @map("product_id")
  size         String?
  is_removed   Boolean  @default(false) @map("is_removed")
  purchased_at DateTime @map("purchased_at")
  created_at   DateTime @default(now()) @map("created_at")
  updated_at   DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, order_id, product_id])
  @@index([user_id, is_removed])
  @@map("personal_closet")
}

model FavoriteBrand {
  id                 String   @id @default(uuid())
  user_id            String   @map("user_id")
  brand_name         String   @map("brand_name")
  logo_url           String?  @map("logo_url") @db.VarChar(2048)
  interaction_count  Int      @default(0) @map("interaction_count")
  preferred_category String?  @map("preferred_category")
  is_removed         Boolean  @default(false) @map("is_removed")
  created_at         DateTime @default(now()) @map("created_at")
  updated_at         DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, brand_name])
  @@index([user_id, is_removed])
  @@map("favorite_brands")
}

model FavoriteColor {
  id            String   @id @default(uuid())
  user_id       String   @map("user_id")
  color_name    String   @map("color_name")
  hex_code      String?  @map("hex_code")
  usage_percent Float    @default(0) @map("usage_percent")
  is_removed    Boolean  @default(false) @map("is_removed")
  created_at    DateTime @default(now()) @map("created_at")
  updated_at    DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, color_name])
  @@index([user_id, is_removed])
  @@map("favorite_colors")
}
