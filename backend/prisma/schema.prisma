generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum UserRole {
  USER
  ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum BodyType {
  SLIM
  ATHLETIC
  AVERAGE
  CURVY
  PLUS_SIZE
}

enum SkinTone {
  FAIR
  LIGHT
  MEDIUM
  OLIVE
  TAN
  BROWN
  DARK
}

enum ProductCategoryGroupCode {
  MEN
  WOMEN
  ACCESSORIES
  FOOTWEAR
}

enum AvatarCategory {
  TOP
  JACKET
  BOTTOM
  FOOTWEAR
  ACCESSORY
}

model User {
  id               String      @id @default(uuid())
  email            String      @unique
  mobile           String?     @unique
  password_hash    String      @map("password_hash")
  role             UserRole    @default(USER)
  status           UserStatus  @default(ACTIVE)
  admin_created_at DateTime?   @map("admin_created_at")
  created_at       DateTime    @default(now()) @map("created_at")
  updated_at       DateTime    @updatedAt @map("updated_at")
  profile          UserProfile?
  wishlist         Wishlist[]
  cart_items       CartItem[]
  orders           Order[]
  fashion_dna   FashionDna?
  fashion_dna_history FashionDnaHistory[]
  face_registration FaceRegistration?
  face_analysis   FaceAnalysis?
  body_analysis   BodyAnalysis?
  digital_avatars DigitalAvatar[]
  virtual_try_on  VirtualTryOn?
  virtual_try_on_results VirtualTryOnResult[]
  try_on_results  TryOnResult[]
  saved_outfits   SavedOutfit[]
  personal_closet PersonalClosetItem[]
  favorite_brands FavoriteBrand[]
  favorite_colors FavoriteColor[]
  product_views ProductView[]
  search_history SearchHistory[]
  support_tickets SupportTicket[] @relation("SupportTicketUser")
  assigned_support_tickets SupportTicket[] @relation("SupportTicketAssignee")
  support_messages SupportMessage[]
  support_attachments SupportAttachment[]
  support_activities SupportActivity[]
  support_assignments SupportAssignment[]
  support_notifications SupportNotification[]
  addresses             UserAddress[]
  order_notifications   OrderNotification[]
  user_notifications    UserNotification[]
  user_media            UserMedia[]

  @@map("users")
}

model FaceRegistration {
  id                 String   @id @default(uuid())
  user_id            String   @unique @map("user_id")
  face_embedding_id  String   @map("face_embedding_id")
  face_image_url     String?  @map("face_image_url") @db.VarChar(2048)
  is_face_registered Boolean  @default(true) @map("is_face_registered")
  liveness_score     Float?   @map("liveness_score")
  blink_detected     Boolean  @default(false) @map("blink_detected")
  smile_detected     Boolean  @default(false) @map("smile_detected")
  registered_at      DateTime @default(now()) @map("registered_at")
  updated_at         DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("face_registrations")
}

model FaceAnalysis {
  id              String   @id @default(uuid())
  user_id         String   @unique @map("user_id")
  face_shape      String?  @map("face_shape")
  skin_tone       String?  @map("skin_tone")
  hair_length     String?  @map("hair_length")
  hair_color      String?  @map("hair_color")
  hair_style      String?  @map("hair_style")
  beard_type      String?  @map("beard_type")
  raw_ai_response Json?    @map("raw_ai_response")
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("face_analysis")
}

model BodyAnalysis {
  id              String   @id @default(uuid())
  user_id         String   @unique @map("user_id")
  body_image_url  String?  @map("body_image_url") @db.VarChar(2048)
  body_type       String?  @map("body_type")
  body_shape      String?  @map("body_shape")
  height          Float?
  shoulder_width  Float?   @map("shoulder_width")
  chest           Float?
  waist           Float?
  hip             Float?
  arm_length      Float?   @map("arm_length")
  leg_length      Float?   @map("leg_length")
  fit_profile     Json?    @map("fit_profile")
  raw_ai_response Json?    @map("raw_ai_response")
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("body_analysis")
}

model DigitalAvatar {
  id              String   @id @default(uuid())
  user_id         String   @map("user_id")
  avatar_type     String   @map("avatar_type")
  avatar_image    String   @map("avatar_image") @db.VarChar(2048)
  version         Int
  is_active       Boolean  @default(false) @map("is_active")
  raw_ai_response Json?    @map("raw_ai_response")
  created_at      DateTime @default(now()) @map("created_at")
  updated_at      DateTime @updatedAt @map("updated_at")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, version])
  @@index([user_id, is_active])
  @@map("digital_avatars")
}

model UserProfile {
  id          String    @id @default(uuid())
  user_id     String    @unique @map("user_id")
  name        String?
  gender      Gender?
  age         Int?
  height      Float?
  weight      Float?
  country     String?
  language    String?
  body_type   BodyType? @map("body_type")
  skin_tone   SkinTone? @map("skin_tone")
  preferences Json?
  body_image  String?   @map("body_image") @db.VarChar(2048)
  user        User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  created_at  DateTime  @default(now()) @map("created_at")
  updated_at  DateTime  @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model ProductCategoryGroup {
  id          String                   @id @default(uuid())
  code        ProductCategoryGroupCode @unique
  name        String
  description String?
  sort_order  Int                      @default(0) @map("sort_order")
  is_active   Boolean                  @default(true) @map("is_active")
  created_at  DateTime                 @default(now()) @map("created_at")
  updated_at  DateTime                 @updatedAt @map("updated_at")
  categories  ProductCategory[]

  @@index([is_active])
  @@index([sort_order])
  @@map("product_category_groups")
}

model ProductCategory {
  id         String               @id @default(uuid())
  group_id   String               @map("group_id")
  slug       String               @unique
  name       String
  sort_order Int                  @default(0) @map("sort_order")
  is_active  Boolean              @default(true) @map("is_active")
  created_at DateTime             @default(now()) @map("created_at")
  updated_at DateTime             @updatedAt @map("updated_at")
  group      ProductCategoryGroup @relation(fields: [group_id], references: [id], onDelete: Cascade)

  @@unique([group_id, name])
  @@index([group_id])
  @@index([is_active])
  @@index([sort_order])
  @@map("product_categories")
}

model Product {
  id                   String         @id @default(uuid())
  sku                  String         @unique
  name                 String
  description          String?
  category             String?
  subcategory          String?
  product_type         String?        @map("product_type")
  gender               String?
  brand                String?
  category_id          String?        @map("category_id")
  brand_id             String?        @map("brand_id")
  price                Float
  mrp                  Float?
  discount_percent     Float?         @map("discount_percent")
  tax_percent          Float?         @map("tax_percent")
  stock_quantity       Int            @default(0) @map("stock_quantity")
  barcode              String?
  visibility           String         @default("PUBLISHED") @map("visibility")
  currency             String         @default("INR")
  color                String?
  size_options         Json?          @map("size_options")
  fabric               String?
  fit_type             String?        @map("fit_type")
  pattern              String?
  sleeve_type          String?        @map("sleeve_type")
  neck_type            String?        @map("neck_type")
  season               String?
  care_instructions    String?        @map("care_instructions")
  country_of_origin    String?        @map("country_of_origin")
  material             String?
  weight_grams         Int?           @map("weight_grams")
  dimensions           Json?
  tags                 Json?
  search_keywords      Json?          @map("search_keywords")
  cms_metadata         Json?          @map("cms_metadata")
  style_tags           Json?          @map("style_tags")
  occasion_tags        Json?          @map("occasion_tags")
  is_featured          Boolean        @default(false) @map("is_featured")
  is_trending          Boolean        @default(false) @map("is_trending")
  is_new_arrival       Boolean        @default(false) @map("is_new_arrival")
  is_best_seller       Boolean        @default(false) @map("is_best_seller")
  is_limited_edition   Boolean        @default(false) @map("is_limited_edition")
  rating_avg           Float?         @map("rating_avg")
  review_count         Int            @default(0) @map("review_count")
  view_count           Int            @default(0) @map("view_count")
  wishlist_count       Int            @default(0) @map("wishlist_count")
  image_url            String?        @map("image_url") @db.VarChar(2048)
  product_url          String?        @map("product_url") @db.VarChar(2048)
  avatar_category      AvatarCategory? @map("avatar_category")
  overlay_order        Int?            @map("overlay_order")
  avatar_overlay_url   String?        @map("avatar_overlay_url") @db.VarChar(2048)
  try_on_image         String?        @map("try_on_image") @db.VarChar(2048)
  is_try_on_compatible Boolean?       @map("is_try_on_compatible")
  is_active            Boolean        @default(true) @map("is_active")
  created_at           DateTime       @default(now()) @map("created_at")
  updated_at           DateTime       @updatedAt @map("updated_at")
  images               ProductImage[]
  variants             ProductVariant[]
  inventory_history    ProductInventoryHistory[]
  wishlist             Wishlist[]
  cart_items           CartItem[]
  product_views        ProductView[]
  orders               Order[]
  try_on_results       TryOnResult[]
  personal_closet_items PersonalClosetItem[]

  @@index([category])
  @@index([subcategory])
  @@index([product_type])
  @@index([category, product_type])
  @@index([gender])
  @@index([brand])
  @@index([category_id])
  @@index([brand_id])
  @@index([price])
  @@index([is_active])
  @@index([visibility])
  @@index([stock_quantity])
  @@index([category, subcategory])
  @@index([gender, category])
  @@index([avatar_category])
  @@index([overlay_order])
  @@index([avatar_category, overlay_order])
  @@map("products")
}

model ProductVariant {
  id               String   @id @default(uuid())
  product_id       String   @map("product_id")
  color            String
  size             String
  sku              String   @unique
  stock            Int      @default(0)
  price_override   Float?   @map("price_override")
  image_url        String?  @map("image_url") @db.VarChar(2048)
  barcode          String?
  is_active        Boolean  @default(true) @map("is_active")
  sort_order       Int      @default(0) @map("sort_order")
  created_at       DateTime @default(now()) @map("created_at")
  updated_at       DateTime @updatedAt @map("updated_at")
  product          Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)
  inventory_history ProductInventoryHistory[]

  @@unique([product_id, color, size])
  @@index([product_id])
  @@index([color])
  @@index([size])
  @@map("product_variants")
}

model ProductInventoryHistory {
  id              String          @id @default(uuid())
  product_id      String          @map("product_id")
  variant_id      String?         @map("variant_id")
  change_type     String          @map("change_type")
  quantity_change Int             @map("quantity_change")
  quantity_before Int             @map("quantity_before")
  quantity_after  Int             @map("quantity_after")
  reason          String?
  admin_user_id   String?         @map("admin_user_id")
  created_at      DateTime        @default(now()) @map("created_at")
  product         Product         @relation(fields: [product_id], references: [id], onDelete: Cascade)
  variant         ProductVariant? @relation(fields: [variant_id], references: [id], onDelete: SetNull)

  @@index([product_id])
  @@index([variant_id])
  @@map("product_inventory_history")
}

model ProductImage {
  id         String   @id @default(uuid())
  product_id String   @map("product_id")
  url        String
  sort_order Int      @default(0) @map("sort_order")
  is_primary Boolean  @default(false) @map("is_primary")
  created_at DateTime @default(now()) @map("created_at")
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([product_id])
  @@map("product_images")
}

model Wishlist {
  id         String   @id @default(uuid())
  user_id    String   @map("user_id")
  product_id String   @map("product_id")
  created_at DateTime @default(now()) @map("created_at")
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@index([user_id])
  @@map("wishlist")
}

enum OrderStatus {
  CREATED
  CONFIRMED
  PACKING
  PACKED
  READY_TO_DISPATCH
  READY_FOR_HANDOVER
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
  REFUNDED
  ARCHIVED
  ON_HOLD
}

enum PaymentMethod {
  COD
  UPI
  CREDIT_CARD
  DEBIT_CARD
  NET_BANKING
  WALLET
}

enum AddressType {
  HOME
  OFFICE
  OTHER
}

enum OrderPriority {
  NORMAL
  HIGH
  URGENT
}

enum OrderDocumentType {
  INVOICE
  SHIPPING_LABEL
}

enum OrderNotificationType {
  ORDER_PLACED
  ORDER_ACCEPTED
  INVOICE_GENERATED
  LABEL_GENERATED
  PACKED
  READY_TO_DISPATCH
  HANDED_OVER
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  RETURNED
  REFUND_APPROVED
  STATUS_UPDATED
}

model CartItem {
  id         String   @id @default(uuid())
  user_id    String   @map("user_id")
  product_id String   @map("product_id")
  quantity   Int      @default(1)
  created_at DateTime @default(now()) @map("created_at")
  updated_at DateTime @updatedAt @map("updated_at")
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, product_id])
  @@index([user_id])
  @@map("cart_items")
}

model Order {
  id                  String         @id @default(uuid())
  user_id             String?        @map("user_id")
  product_id          String?        @map("product_id")
  order_number        String?        @unique @map("order_number")
  invoice_number      String?        @unique @map("invoice_number")
  total_amount        Float          @map("total_amount")
  subtotal            Float?
  shipping            Float?
  discount            Float?
  tax                 Float?
  coupon_code         String?        @map("coupon_code")
  payment_method      PaymentMethod? @map("payment_method")
  payment_status      String?        @default("pending") @map("payment_status")
  shipping_address    Json?          @map("shipping_address")
  billing_address     Json?          @map("billing_address")
  priority            OrderPriority  @default(NORMAL)
  estimated_delivery  DateTime?      @map("estimated_delivery")
  tracking_number     String?        @map("tracking_number")
  courier_name        String?        @map("courier_name")
  package_weight      Float?         @map("package_weight")
  package_id          String?        @map("package_id")
  label_generated_at  DateTime?      @map("label_generated_at")
  invoice_generated_at DateTime?     @map("invoice_generated_at")
  packed_at           DateTime?      @map("packed_at")
  dispatched_at       DateTime?      @map("dispatched_at")
  delivered_at        DateTime?      @map("delivered_at")
  completed_at        DateTime?      @map("completed_at")
  internal_notes      String?        @map("internal_notes")
  metadata            Json?
  oms_metadata        Json?          @map("oms_metadata")
  status              OrderStatus    @default(CREATED)
  created_at          DateTime       @default(now()) @map("created_at")
  updated_at          DateTime       @updatedAt @map("updated_at")
  user                User?          @relation(fields: [user_id], references: [id], onDelete: SetNull)
  product             Product?       @relation(fields: [product_id], references: [id], onDelete: SetNull)
  timeline            OrderTimeline[]
  documents           OrderDocument[]
  notifications       OrderNotification[]

  @@index([user_id])
  @@index([status])
  @@index([product_id])
  @@index([order_number])
  @@index([invoice_number])
  @@index([tracking_number])
  @@index([created_at])
  @@map("orders")
}

model UserAddress {
  id              String      @id @default(uuid())
  user_id         String      @map("user_id")
  full_name       String      @map("full_name")
  phone           String
  alternate_phone String?     @map("alternate_phone")
  country         String      @default("India")
  state           String
  city            String
  pincode         String
  house_no        String      @map("house_no")
  landmark        String?
  address_type    AddressType @default(HOME) @map("address_type")
  is_default      Boolean     @default(false) @map("is_default")
  created_at      DateTime    @default(now()) @map("created_at")
  updated_at      DateTime    @updatedAt @map("updated_at")
  user            User        @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id])
  @@index([user_id, is_default])
  @@map("user_addresses")
}

model OrderTimeline {
  id          String      @id @default(uuid())
  order_id    String      @map("order_id")
  action      String
  from_status OrderStatus? @map("from_status")
  to_status   OrderStatus? @map("to_status")
  actor_id    String?     @map("actor_id")
  actor_role  String?     @map("actor_role")
  notes       String?
  metadata    Json?
  created_at  DateTime    @default(now()) @map("created_at")
  order       Order       @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([created_at])
  @@map("order_timeline")
}

model OrderDocument {
  id            String            @id @default(uuid())
  order_id      String            @map("order_id")
  document_type OrderDocumentType @map("document_type")
  file_name     String            @map("file_name")
  storage_path  String            @map("storage_path")
  mime_type     String            @default("application/pdf") @map("mime_type")
  version       Int               @default(1)
  generated_by  String?           @map("generated_by")
  created_at    DateTime          @default(now()) @map("created_at")
  order         Order             @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([order_id])
  @@index([order_id, document_type])
  @@map("order_documents")
}

model OrderNotification {
  id         String                @id @default(uuid())
  user_id    String                @map("user_id")
  order_id   String                @map("order_id")
  type       OrderNotificationType
  title      String
  message    String
  is_read    Boolean               @default(false) @map("is_read")
  metadata   Json?
  created_at DateTime              @default(now()) @map("created_at")
  user       User                  @relation(fields: [user_id], references: [id], onDelete: Cascade)
  order      Order                 @relation(fields: [order_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
  @@index([order_id])
  @@map("order_notifications")
}

model FashionDna {
  id                       String   @id @default(uuid())
  user_id                  String   @unique @map("user_id")
  style_type               String   @map("style_type")
  color_affinity           Json     @map("color_affinity")
  budget_range             String   @map("budget_range")
  brand_affinity           Json     @map("brand_affinity")
  fashion_confidence_score Float    @map("fashion_confidence_score")
  face_traits              Json     @map("face_traits")
  body_traits              Json     @map("body_traits")
  preference_traits        Json     @map("preference_traits")
  activity_traits          Json     @default("{}") @map("activity_traits")
  created_at               DateTime @default(now()) @map("created_at")
  updated_at               DateTime @updatedAt @map("updated_at")
  user                     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("fashion_dna")
}

model FashionDnaHistory {
  id                       String   @id @default(uuid())
  user_id                  String   @map("user_id")
  fashion_dna_id           String   @map("fashion_dna_id")
  change_reason            String   @map("change_reason")
  change_source            String?  @map("change_source")
  style_type               String   @map("style_type")
  color_affinity           Json     @map("color_affinity")
  budget_range             String   @map("budget_range")
  brand_affinity           Json     @map("brand_affinity")
  fashion_confidence_score Float    @map("fashion_confidence_score")
  face_traits              Json     @map("face_traits")
  body_traits              Json     @map("body_traits")
  preference_traits        Json     @map("preference_traits")
  activity_traits          Json     @default("{}") @map("activity_traits")
  dna_created_at           DateTime @map("dna_created_at")
  dna_updated_at           DateTime @map("dna_updated_at")
  archived_at              DateTime @default(now()) @map("archived_at")
  user                     User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, archived_at])
  @@index([fashion_dna_id])
  @@map("fashion_dna_history")
}

model ProductView {
  id         String   @id @default(uuid())
  user_id    String   @map("user_id")
  product_id String   @map("product_id")
  viewed_at  DateTime @default(now()) @map("viewed_at")
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product    Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@index([user_id, viewed_at])
  @@index([product_id])
  @@map("product_views")
}

model SearchHistory {
  id          String   @id @default(uuid())
  user_id     String   @map("user_id")
  query       String
  searched_at DateTime @default(now()) @map("searched_at")
  user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, searched_at])
  @@map("search_history")
}

model VirtualTryOn {
  id                     String   @id @default(uuid())
  user_id                String   @unique @map("user_id")
  body_image             String?  @map("body_image") @db.VarChar(2048)
  transparent_image      String?  @map("transparent_image") @db.VarChar(2048)
  selected_products      Json     @default("[]") @map("selected_products")
  generated_outfit_image String?  @map("generated_outfit_image") @db.VarChar(2048)
  created_at             DateTime @default(now()) @map("created_at")
  updated_at             DateTime @updatedAt @map("updated_at")
  user                   User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("virtual_try_on")
}

model VirtualTryOnResult {
  id                   String   @id @default(uuid())
  user_id              String   @map("user_id")
  product_id           String?  @map("product_id")
  body_photo_reference String?  @map("body_photo_reference") @db.VarChar(2048)
  garment_image        String?  @map("garment_image") @db.VarChar(2048)
  input_image          String?  @map("input_image") @db.VarChar(2048)
  transparent_image    String?  @map("transparent_image") @db.VarChar(2048)
  generated_image      String?  @map("generated_image") @db.VarChar(2048)
  selected_products    Json     @default("[]") @map("selected_products")
  created_at           DateTime @default(now()) @map("created_at")
  user                 User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@map("virtual_tryons")
}

model TryOnResult {
  id              String   @id @default(uuid())
  user_id         String   @map("user_id")
  product_id      String?  @map("product_id")
  body_image      String?  @map("body_image") @db.VarChar(2048)
  garment_image   String?  @map("garment_image") @db.VarChar(2048)
  generated_image String?  @map("generated_image") @db.VarChar(2048)
  created_at      DateTime @default(now()) @map("created_at")
  user            User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product         Product? @relation(fields: [product_id], references: [id], onDelete: SetNull)

  @@index([user_id, created_at])
  @@index([product_id])
  @@map("try_on_results")
}

model SavedOutfit {
  id            String   @id @default(uuid())
  user_id       String   @map("user_id")
  name          String?
  products      Json     @default("[]")
  items         Json     @default("[]")
  preview_image String?  @map("preview_image") @db.VarChar(2048)
  thumbnail     String?  @db.VarChar(2048)
  total_price   Float?   @map("total_price")
  source        String?
  created_at    DateTime @default(now()) @map("created_at")
  updated_at    DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, created_at])
  @@map("saved_outfits")
}

model PersonalClosetItem {
  id           String   @id @default(uuid())
  user_id      String   @map("user_id")
  order_id     String   @map("order_id")
  product_id   String   @map("product_id")
  size         String?
  is_removed   Boolean  @default(false) @map("is_removed")
  purchased_at DateTime @map("purchased_at")
  created_at   DateTime @default(now()) @map("created_at")
  updated_at   DateTime @updatedAt @map("updated_at")
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
  product      Product  @relation(fields: [product_id], references: [id], onDelete: Cascade)

  @@unique([user_id, order_id, product_id])
  @@index([user_id, is_removed])
  @@map("personal_closet")
}

model FavoriteBrand {
  id                 String   @id @default(uuid())
  user_id            String   @map("user_id")
  brand_name         String   @map("brand_name")
  logo_url           String?  @map("logo_url") @db.VarChar(2048)
  interaction_count  Int      @default(0) @map("interaction_count")
  preferred_category String?  @map("preferred_category")
  is_removed         Boolean  @default(false) @map("is_removed")
  created_at         DateTime @default(now()) @map("created_at")
  updated_at         DateTime @updatedAt @map("updated_at")
  user               User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, brand_name])
  @@index([user_id, is_removed])
  @@map("favorite_brands")
}

model FavoriteColor {
  id            String   @id @default(uuid())
  user_id       String   @map("user_id")
  color_name    String   @map("color_name")
  hex_code      String?  @map("hex_code")
  usage_percent Float    @default(0) @map("usage_percent")
  is_removed    Boolean  @default(false) @map("is_removed")
  created_at    DateTime @default(now()) @map("created_at")
  updated_at    DateTime @updatedAt @map("updated_at")
  user          User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([user_id, color_name])
  @@index([user_id, is_removed])
  @@map("favorite_colors")
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  WAITING_FOR_CUSTOMER
  RESOLVED
  CLOSED
  REOPENED
  ESCALATED
  CANCELLED
}

enum SupportTicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum SupportTicketCategory {
  GENERAL
  TECHNICAL_ISSUE
  FACE_LOGIN
  VIRTUAL_TRY_ON
  AVATAR
  FASHION_DNA
  ORDERS
  PAYMENTS
  CART
  PRODUCTS
  RECOMMENDATION
  ACCOUNT
  SUBSCRIPTION
  BUG_REPORT
  FEATURE_REQUEST
  OTHER
}

enum SupportContactMethod {
  EMAIL
  PHONE
  IN_APP
}

enum SupportMessageAuthorType {
  USER
  ADMIN
  SYSTEM
}

enum SupportActivityType {
  CREATED
  UPDATED
  REPLIED
  ASSIGNED
  PRIORITY_CHANGED
  STATUS_CHANGED
  CATEGORY_CHANGED
  CLOSED
  REOPENED
  ESCALATED
  VIEWED
  ATTACHMENT_DOWNLOADED
  INTERNAL_NOTE
  DELETED
}

enum SupportNotificationType {
  TICKET_CREATED
  ADMIN_REPLIED
  USER_REPLIED
  STATUS_CHANGED
  RESOLVED
  CLOSED
  REOPENED
  ESCALATED
  ASSIGNED
}

enum SupportAttachmentType {
  SCREENSHOT
  FILE
}

model SupportTicket {
  id                 String                @id @default(uuid())
  ticket_number      String                @unique @map("ticket_number")
  user_id            String                @map("user_id")
  subject            String
  description        String                @db.Text
  category           SupportTicketCategory
  priority           SupportTicketPriority @default(MEDIUM)
  status             SupportTicketStatus   @default(OPEN)
  contact_method     SupportContactMethod? @map("contact_method")
  callback_number    String?               @map("callback_number")
  order_reference    String?               @map("order_reference")
  product_reference  String?               @map("product_reference")
  ai_feature_related Boolean?              @map("ai_feature_related")
  assigned_to_id     String?               @map("assigned_to_id")
  browser_info       String?               @map("browser_info")
  device_info        String?               @map("device_info")
  os_info            String?               @map("os_info")
  app_version        String?               @map("app_version")
  timezone           String?
  page_url           String?               @map("page_url") @db.VarChar(2048)
  metadata           Json?
  first_response_at  DateTime?             @map("first_response_at")
  resolved_at        DateTime?             @map("resolved_at")
  due_date           DateTime?             @map("due_date")
  deleted_at         DateTime?             @map("deleted_at")
  created_at         DateTime              @default(now()) @map("created_at")
  updated_at         DateTime              @updatedAt @map("updated_at")
  user               User                  @relation("SupportTicketUser", fields: [user_id], references: [id], onDelete: Cascade)
  assigned_to        User?                 @relation("SupportTicketAssignee", fields: [assigned_to_id], references: [id], onDelete: SetNull)
  messages           SupportMessage[]
  attachments        SupportAttachment[]
  activities         SupportActivity[]
  assignments        SupportAssignment[]
  notifications      SupportNotification[]

  @@index([user_id])
  @@index([status])
  @@index([category])
  @@index([priority])
  @@index([assigned_to_id])
  @@index([ticket_number])
  @@index([created_at])
  @@map("support_tickets")
}

model SupportMessage {
  id          String                   @id @default(uuid())
  ticket_id   String                   @map("ticket_id")
  author_id   String?                  @map("author_id")
  author_type SupportMessageAuthorType @map("author_type")
  body        String                   @db.Text
  is_internal Boolean                  @default(false) @map("is_internal")
  is_read     Boolean                  @default(false) @map("is_read")
  read_at     DateTime?                @map("read_at")
  created_at  DateTime                 @default(now()) @map("created_at")
  ticket      SupportTicket            @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  author      User?                    @relation(fields: [author_id], references: [id], onDelete: SetNull)
  attachments SupportAttachment[]

  @@index([ticket_id])
  @@index([author_id])
  @@map("support_messages")
}

model SupportAttachment {
  id              String                @id @default(uuid())
  ticket_id       String                @map("ticket_id")
  message_id      String?               @map("message_id")
  file_name       String                @map("file_name")
  mime_type       String                @map("mime_type")
  file_size       Int                   @map("file_size")
  storage_path    String                @map("storage_path") @db.VarChar(2048)
  public_url      String                @map("public_url") @db.VarChar(2048)
  attachment_type SupportAttachmentType @map("attachment_type")
  uploaded_by_id  String?               @map("uploaded_by_id")
  created_at      DateTime              @default(now()) @map("created_at")
  ticket          SupportTicket         @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  message         SupportMessage?       @relation(fields: [message_id], references: [id], onDelete: SetNull)
  uploaded_by     User?                 @relation(fields: [uploaded_by_id], references: [id], onDelete: SetNull)

  @@index([ticket_id])
  @@index([message_id])
  @@map("support_attachments")
}

model SupportActivity {
  id            String              @id @default(uuid())
  ticket_id     String              @map("ticket_id")
  actor_id      String?             @map("actor_id")
  activity_type SupportActivityType @map("activity_type")
  old_value     String?             @map("old_value")
  new_value     String?             @map("new_value")
  metadata      Json?
  created_at    DateTime            @default(now()) @map("created_at")
  ticket        SupportTicket       @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  actor         User?               @relation(fields: [actor_id], references: [id], onDelete: SetNull)

  @@index([ticket_id])
  @@index([activity_type])
  @@map("support_activities")
}

model SupportAssignment {
  id           String        @id @default(uuid())
  ticket_id    String        @map("ticket_id")
  assignee_id  String        @map("assignee_id")
  assigned_by  String?       @map("assigned_by")
  note         String?
  is_active    Boolean       @default(true) @map("is_active")
  created_at   DateTime      @default(now()) @map("created_at")
  ticket       SupportTicket @relation(fields: [ticket_id], references: [id], onDelete: Cascade)
  assignee     User          @relation(fields: [assignee_id], references: [id], onDelete: Cascade)

  @@index([ticket_id])
  @@index([assignee_id])
  @@map("support_assignments")
}

model SupportNotification {
  id                String                  @id @default(uuid())
  user_id           String                  @map("user_id")
  ticket_id         String                  @map("ticket_id")
  notification_type SupportNotificationType @map("notification_type")
  title             String
  body              String?
  is_read           Boolean                 @default(false) @map("is_read")
  read_at           DateTime?               @map("read_at")
  metadata          Json?
  created_at        DateTime                @default(now()) @map("created_at")
  user              User                    @relation(fields: [user_id], references: [id], onDelete: Cascade)
  ticket            SupportTicket           @relation(fields: [ticket_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
  @@index([ticket_id])
  @@map("support_notifications")
}

enum NotificationCategory {
  ORDERS
  SUPPORT
  SHOPPING
  SECURITY
  SYSTEM
  PROFILE
  ADMIN
}

model UserNotification {
  id          String               @id @default(uuid())
  user_id     String               @map("user_id")
  category    NotificationCategory
  type        String
  title       String
  description String?
  is_read     Boolean              @default(false) @map("is_read")
  read_at     DateTime?            @map("read_at")
  action_path String?              @map("action_path") @db.VarChar(2048)
  entity_type String?              @map("entity_type")
  entity_id   String?              @map("entity_id")
  metadata    Json?
  created_at  DateTime             @default(now()) @map("created_at")
  user        User                 @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, is_read])
  @@index([user_id, category])
  @@index([user_id, created_at])
  @@map("user_notifications")
}

model UserMedia {
  id                 String    @id @default(uuid())
  user_id            String    @map("user_id")
  module             String
  original_file_name String?   @map("original_file_name")
  stored_file_name   String?   @map("stored_file_name")
  storage_path       String    @map("storage_path") @db.VarChar(2048)
  public_url         String?   @map("public_url") @db.VarChar(2048)
  thumbnail_url      String?   @map("thumbnail_url") @db.VarChar(2048)
  file_size          Int?      @map("file_size")
  width              Int?
  height             Int?
  mime_type          String?   @map("mime_type")
  upload_source      String?   @map("upload_source")
  status             String    @default("ACTIVE")
  metadata           Json?
  created_at         DateTime  @default(now()) @map("created_at")
  updated_at         DateTime  @updatedAt @map("updated_at")
  deleted_at         DateTime? @map("deleted_at")
  user               User      @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@index([user_id, module, status])
  @@index([user_id, created_at])
  @@map("user_media")
}

/// SKUs manually deleted by an admin so automated product seeds must not recreate them.
model SeedSuppressedSku {
  sku        String   @id @db.VarChar(128)
  created_at DateTime @default(now()) @map("created_at")

  @@map("seed_suppressed_skus")
}
