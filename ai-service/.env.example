AI_SERVICE_HOST=0.0.0.0
AI_SERVICE_PORT=8000

# When backend runs in Docker and ai-service runs locally, point to shared uploads:
# UPLOADS_ROOT=../backend/uploads

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_CACHE_TTL=3600

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_FACE_COLLECTION=users_face_vectors
QDRANT_PRODUCT_COLLECTION=products
QDRANT_DNA_COLLECTION=fashion_dna_vectors
QDRANT_FACE_ANALYSIS_COLLECTION=face_analysis_vectors
QDRANT_BODY_ANALYSIS_COLLECTION=body_analysis_vectors
QDRANT_DIGITAL_AVATAR_COLLECTION=digital_avatar_vectors

INSIGHTFACE_MODEL=buffalo_sc
FACE_VECTOR_SIZE=512
FACE_SIMILARITY_THRESHOLD=0.40
FACE_VERIFY_THRESHOLD=0.52
FACE_REGISTRATION_DUPLICATE_THRESHOLD=0.45
FACE_SIMILARITY_UNCERTAIN=0.32

# Webcam liveness tuning (lower = more lenient for registration/login)
FACE_HOLD_STILL_MIN_DETECTION_SCORE=0.45
FACE_LIVENESS_MIN_DETECTION_SCORE=0.35
FACE_MIN_BLUR_VARIANCE=45.0
FACE_LIVENESS_BLUR_VARIANCE=22.0
FACE_MIN_EMBEDDING_CONFIDENCE=0.35

PRODUCT_VECTOR_SIZE=384
DNA_VECTOR_SIZE=384
FACE_ANALYSIS_VECTOR_SIZE=384
BODY_ANALYSIS_VECTOR_SIZE=384
DIGITAL_AVATAR_VECTOR_SIZE=384

SENTENCE_MODEL=all-MiniLM-L6-v2

# Hugging Face token for CatVTON ZeroGPU quota (needs HF PRO for best results)
HF_TOKEN=

# When CatVTON ZeroGPU quota is exhausted, allow local overlay fallback (default: false when HF_TOKEN is set)
TRYON_FALLBACK_ON_QUOTA_EXCEEDED=false
TRYON_TIMEOUT_SECONDS=120
TRYON_MAX_RETRIES=3
